<mxfile host="app.diagrams.net" modified="2026-06-03T00:00:00.000Z" agent="ChatGPT" version="24.7.17"><diagram name="Sync offline basica"><mxGraphModel dx="1422" dy="794" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1920" pageHeight="1080" math="0" shadow="0"><root><mxCell id="0" /><mxCell id="1" parent="0" /><mxCell id="2" value="&lt;b&gt;NANU TECH - Sincronización offline básica móvil&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#607080&quot;&gt;Registro local de eventos del chofer y posterior sincronización con el backend&lt;/font&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=30;fontStyle=0;fontColor=#1F2933;" vertex="1" parent="1"><mxGeometry as="geometry" x="70" y="45" width="1650" height="70" /></mxCell><mxCell id="3" value="&lt;b&gt;Chofer&lt;/b&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#F3F4F6;strokeColor=#9AA5B1;fontColor=#1F2933;fontSize=18;fontStyle=0;spacing=8;" vertex="1" parent="1"><mxGeometry as="geometry" x="70" y="355" width="180" height="82" /></mxCell><mxCell id="4" value="&lt;b&gt;App móvil Flutter&lt;/b&gt;&lt;br&gt;jornada, observaciones, SOS y auxilio" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#4D8B5D;fontColor=#1F2933;fontSize=20;fontStyle=0;spacing=8;" vertex="1" parent="1"><mxGeometry as="geometry" x="330" y="300" width="280" height="160" /></mxCell><mxCell id="5" value="&lt;b&gt;Monitor de conectividad&lt;/b&gt;&lt;br&gt;detecta si hay o no acceso real a internet" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#4F7CAC;fontColor=#1F2933;fontSize=18;fontStyle=0;spacing=8;" vertex="1" parent="1"><mxGeometry as="geometry" x="715" y="240" width="285" height="110" /></mxCell><mxCell id="6" value="&lt;b&gt;SQLite local&lt;/b&gt;&lt;br&gt;offline_events, jornada_cache y sync_logs" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#F1EDFF;strokeColor=#6B5DD3;fontColor=#1F2933;fontSize=20;fontStyle=0;spacing=8;" vertex="1" parent="1"><mxGeometry as="geometry" x="700" y="430" width="300" height="160" /></mxCell><mxCell id="7" value="&lt;b&gt;API Gateway&lt;/b&gt;&lt;br&gt;reenvío de eventos" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#B7791F;fontColor=#1F2933;fontSize=18;fontStyle=0;spacing=8;" vertex="1" parent="1"><mxGeometry as="geometry" x="1120" y="310" width="220" height="82" /></mxCell><mxCell id="8" value="&lt;b&gt;JornadaFunction / AlertaFunction&lt;/b&gt;&lt;br&gt;procesa START, END, SOS y AUXILIO" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#B7791F;fontColor=#1F2933;fontSize=18;fontStyle=0;spacing=8;" vertex="1" parent="1"><mxGeometry as="geometry" x="1440" y="260" width="280" height="150" /></mxCell><mxCell id="9" value="&lt;b&gt;PostgreSQL&lt;/b&gt;&lt;br&gt;persistencia central del estado operativo" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#F1EDFF;strokeColor=#6B5DD3;fontColor=#1F2933;fontSize=18;fontStyle=0;spacing=8;" vertex="1" parent="1"><mxGeometry as="geometry" x="1450" y="540" width="260" height="120" /></mxCell><mxCell id="10" value="&lt;b&gt;1. Sin conexión&lt;/b&gt;&lt;br&gt;la acción se guarda localmente" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#EAF7EF;strokeColor=#4D8B5D;fontColor=#1F2933;fontSize=16;fontStyle=0;spacing=8;" vertex="1" parent="1"><mxGeometry as="geometry" x="330" y="720" width="250" height="86" /></mxCell><mxCell id="11" value="&lt;b&gt;2. Vuelve la conexión&lt;/b&gt;&lt;br&gt;se leen eventos por prioridad" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#EAF2FF;strokeColor=#4F7CAC;fontColor=#1F2933;fontSize=16;fontStyle=0;spacing=8;" vertex="1" parent="1"><mxGeometry as="geometry" x="650" y="720" width="250" height="86" /></mxCell><mxCell id="12" value="&lt;b&gt;3. Reenvío&lt;/b&gt;&lt;br&gt;cada evento se envía al backend" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#FFF4DE;strokeColor=#B7791F;fontColor=#1F2933;fontSize=16;fontStyle=0;spacing=8;" vertex="1" parent="1"><mxGeometry as="geometry" x="970" y="720" width="250" height="86" /></mxCell><mxCell id="13" value="&lt;b&gt;4. Confirmación&lt;/b&gt;&lt;br&gt;el evento queda sincronizado" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#F1EDFF;strokeColor=#6B5DD3;fontColor=#1F2933;fontSize=16;fontStyle=0;spacing=8;" vertex="1" parent="1"><mxGeometry as="geometry" x="1290" y="720" width="250" height="86" /></mxCell><mxCell id="14" value="El MVP no plantea sincronización avanzada en segundo plano. Se defiende como offline básico controlado con cola local y sincronización posterior." style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#4D8B5D;fontColor=#1F2933;fontSize=14;fontStyle=0;spacing=8;" vertex="1" parent="1"><mxGeometry as="geometry" x="290" y="900" width="540" height="95" /></mxCell><mxCell id="15" value="La prioridad funcional es conservar continuidad operativa del chofer, mantener trazabilidad de los eventos y centralizar la verdad final en PostgreSQL." style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#B7791F;fontColor=#1F2933;fontSize=14;fontStyle=0;spacing=8;" vertex="1" parent="1"><mxGeometry as="geometry" x="900" y="900" width="790" height="95" /></mxCell><mxCell id="16" value="1. Ejecuta acción" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=14;fontColor=#607080;" vertex="1" parent="1"><mxGeometry as="geometry" x="255" y="355" width="300" height="30" /></mxCell><mxCell id="17" value="2. Verifica conectividad" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=14;fontColor=#607080;" vertex="1" parent="1"><mxGeometry as="geometry" x="620" y="315" width="300" height="30" /></mxCell><mxCell id="18" value="sin conexión" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=13;fontColor=#607080;" vertex="1" parent="1"><mxGeometry as="geometry" x="865" y="395" width="300" height="30" /></mxCell><mxCell id="19" value="3. Guarda evento pendiente" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=14;fontColor=#607080;" vertex="1" parent="1"><mxGeometry as="geometry" x="605" y="470" width="300" height="30" /></mxCell><mxCell id="20" value="4. Recupera conexión y reenvía" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=13;fontColor=#607080;" vertex="1" parent="1"><mxGeometry as="geometry" x="1010" y="470" width="300" height="30" /></mxCell><mxCell id="21" value="5. Procesa" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=13;fontColor=#607080;" vertex="1" parent="1"><mxGeometry as="geometry" x="1350" y="315" width="300" height="30" /></mxCell><mxCell id="22" value="6. Persiste" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=13;fontColor=#607080;" vertex="1" parent="1"><mxGeometry as="geometry" x="1590" y="470" width="300" height="30" /></mxCell><mxCell id="23" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#4D8B5D;strokeWidth=2;fontSize=12;fontColor=#4B5563;" edge="1" parent="1" source="3" target="4"><mxGeometry as="geometry" relative="1" /></mxCell><mxCell id="24" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#4F7CAC;strokeWidth=2;fontSize=12;fontColor=#4B5563;" edge="1" parent="1" source="4" target="5"><mxGeometry as="geometry" relative="1" /></mxCell><mxCell id="25" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#4F7CAC;strokeWidth=2;fontSize=12;fontColor=#4B5563;" edge="1" parent="1" source="5" target="6"><mxGeometry as="geometry" relative="1" /></mxCell><mxCell id="26" value